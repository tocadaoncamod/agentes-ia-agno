# ============================================================
#  CONFIGURAÇÃO DO AGENTE MAESTRO
#  Copie este arquivo para .env e preencha suas chaves de API
# ============================================================

# OBRIGATÓRIO — OpenAI (para o AgenteMaestro)
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-cole-sua-chave-aqui

# OPCIONAL — Groq (modelos rápidos e gratuitos)
# Crie em: https://console.groq.com/keys
GROQ_API_KEY=gsk_cole-sua-chave-aqui

# OPCIONAL — Tavily (busca na web de alta qualidade)
# Crie em: https://app.tavily.com/
TAVILY_API_KEY=tvly-cole-sua-chave-aqui

# Modelo padrão (gpt-4.1-mini é o mais barato e capaz)
AGENTE_MODELO=gpt-4.1-mini
